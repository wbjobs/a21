DATABASE_URL=postgresql://postgres:password@localhost:5432/webauthn_voiceprint
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_TOKEN_EXPIRE_MINUTES=120

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=VoiceAuth
WEBAUTHN_ORIGIN=http://localhost:5173

MFCC_N_MFCC=40
VOICEPRINT_SIMILARITY_THRESHOLD=0.70
USE_DTW_ALIGNMENT=true
DTW_WINDOW_SIZE=50
USE_SIAMESE_MODEL=true
SIAMESE_EMBEDDING_DIM=128
MODEL_DIR=models

SIMILARITY_WEIGHT_MODEL=0.5
SIMILARITY_WEIGHT_DTW=0.3
SIMILARITY_WEIGHT_COSINE=0.2
FEATURE_NORMALIZATION=cmvn_histogram

ENABLE_FALLBACK_MODE=true
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_TIMEOUT_SECONDS=60
FALLBACK_CACHE_TTL_MINUTES=30

ENABLE_ANOMALY_DETECTION=true
MULTI_LOCATION_WINDOW_MINUTES=30
HIGH_FREQ_ATTEMPTS_WINDOW_SECONDS=300
HIGH_FREQ_ATTEMPTS_THRESHOLD=15
VOICEPRINT_REUSE_THRESHOLD=0.85

DEFAULT_TENANT_NAME=Default
DEFAULT_TENANT_DOMAIN=default.local
DEFAULT_TENANT_LANGUAGE=zh-CN

RECONCILIATION_WORKER_INTERVAL_SECONDS=10
FALLBACK_CACHE_DIR=fallback_cache
RECONCILIATION_MAX_AGE_HOURS=24

REDIS_URL=
