DATABASE_URL=postgresql://postgres:password@localhost:5432/webauthn_voiceprint
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=VoiceAuth
WEBAUTHN_ORIGIN=http://localhost:5173
MFCC_N_MFCC=40

VOICEPRINT_SIMILARITY_THRESHOLD=0.70
USE_DTW_ALIGNMENT=true
DTW_WINDOW_SIZE=50
USE_SIAMESE_MODEL=true
SIAMESE_EMBEDDING_DIM=128
MODEL_DIR=models

SIMILARITY_WEIGHT_MODEL=0.5
SIMILARITY_WEIGHT_DTW=0.3
SIMILARITY_WEIGHT_COSINE=0.2
FEATURE_NORMALIZATION=cmvn_histogram
